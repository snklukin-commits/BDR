# Почта BSS через IMAP/SMTP
IMAP_HOST=mx03.bsspharm.ru
IMAP_PORT=993
IMAP_USE_SSL=true
SMTP_HOST=mx03.bsspharm.ru
SMTP_PORT=587
SMTP_STARTTLS=true

# Секреты. Не коммитить реальный .env в GitHub.
MAIL_USER=your_work_email_login
MAIL_PASSWORD=your_work_email_password
MAIL_FROM=your_work_email_login

# Для ИИ нужен API-ключ. Подписка ChatGPT Plus/Pro сама по себе не является API-ключом.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Автоматическая проверка
CHECK_INTERVAL_SECONDS=300
MAX_EMAILS_PER_CHECK=30

# Необязательно: автоотчёт на почту после появления новых сообщений
AUTO_EMAIL_REPORT_ENABLED=false
AUTO_EMAIL_REPORT_TO=your_personal_email@example.com

# Хранилище
DB_PATH=mail_ai.sqlite3
